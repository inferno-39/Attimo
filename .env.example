# =============================================================================
# PostgreSQL (Prisma). Схема: src/prisma/schema.prisma
# ВАЖНО: сюда только ПРИМЕРЫ без реальных паролей. Секреты — только в файле .env (он в .gitignore).
# Локально: один и тот же URI в DATABASE_URL и DIRECT_URL.
# Supabase: см. блок ниже (IPv4 / Prisma).
# =============================================================================

# Prisma Client (runtime): локальный Postgres или Supabase.
# Supabase Dashboard → Connect → выберите режим строки (см. ниже).
# Если в пароле есть @ # и т.п. — закодируйте в URI (например @ → %40).
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/attimo?schema=public"

# prisma migrate / db push / introspect.
# Локально без Supabase: продублируйте DATABASE_URL.
# Supabase + IPv4: прямой db.*.supabase.co:5432 часто НЕ доступен (P1001) — используйте Session pooler:
#   DIRECT_URL="postgresql://postgres.<PROJECT_REF>:PASSWORD@aws-0-<REGION>.pooler.supabase.com:5432/postgres"
# Supabase + Prisma runtime через Transaction pooler (serverless-friendly):
#   DATABASE_URL="postgresql://postgres.<PROJECT_REF>:PASSWORD@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Либо для простого старта с IPv4: и DATABASE_URL, и DIRECT_URL = одна и та же Session pooler строка (:5432, без ?pgbouncer=true).
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/attimo?schema=public"

# --- Supabase + ошибка P1001 «Can't reach database» с ПК на IPv4 ---
# Не используйте только Direct connection (db.*.supabase.co:5432) — он по умолчанию IPv6.
# Возьмите в Dashboard «Session pooler» (pooler.supabase.com, порт 5432) в DIRECT_URL и при необходимости в DATABASE_URL.
# Док: https://supabase.com/docs/guides/database/connecting-to-postgres#pooler-session-mode

# Auth.js / NextAuth (см. https://authjs.dev)
# Сгенерировать: openssl rand -base64 32
AUTH_SECRET=""
# Базовый URL приложения (для продакшена / Netlify)
AUTH_URL="http://localhost:3000"
