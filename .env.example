# =============================================================================
# PostgreSQL (Prisma). Схема: src/prisma/schema.prisma
# Локально: один и тот же URI в DATABASE_URL и DIRECT_URL.
# Supabase: пул в DATABASE_URL, прямой хост в DIRECT_URL (иначе migrate/push падают на PgBouncer).
# =============================================================================

# Prisma Client (runtime): локальный Postgres или Supabase Session / Transaction pooler (порт 6543).
# Supabase: Dashboard → Project Settings → Database → Connection string → «URI» или «Pooling».
# Часто нужно: ?sslmode=require (добавьте, если SSL требуется и не вшит в строку).
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/attimo?schema=public"

# Прямое подключение без PgBouncer (только для prisma migrate / db push / introspect).
# Локально: продублируйте значение DATABASE_URL.
# Supabase: тот же раздел → «Direct connection» (хост вида db.<ref>.supabase.co, порт 5432).
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/attimo?schema=public"

# Auth.js / NextAuth (см. https://authjs.dev)
# Сгенерировать: openssl rand -base64 32
AUTH_SECRET=""
# Базовый URL приложения (для продакшена / Netlify)
AUTH_URL="http://localhost:3000"
